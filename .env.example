# US Visa Appointment Bot — Configuration
# Copy this file to .env and fill in your values

# ── Credentials ───────────────────────────────────────────────────────────────
EMAIL=your.email@example.com
PASSWORD=yourpassword

# ── Location ──────────────────────────────────────────────────────────────────
# Found in the URL: https://ais.usvisa-info.com/en-{COUNTRY_CODE}/
# Examples: ke (Kenya), fr (France), br (Brazil), de (Germany)
COUNTRY_CODE=ke

# Found in the URL when rescheduling:
# https://ais.usvisa-info.com/en-{COUNTRY_CODE}/niv/schedule/{SCHEDULE_ID}/continue_actions
SCHEDULE_ID=12345678

# Found in DevTools → Network tab when loading the reschedule page
# Look for: appointment/days/{FACILITY_ID}.json
FACILITY_ID=104

# ── Date Range ────────────────────────────────────────────────────────────────
# Bot only considers slots within this window (inclusive, YYYY-MM-DD)
MIN_DATE=2026-05-23
TARGET_DATE=2026-06-05

# ── Polling ───────────────────────────────────────────────────────────────────
# Seconds between each availability check (default: 10)
REFRESH_DELAY=30

# Max consecutive errors before the bot stops (default: 10)
MAX_RETRIES=10

# ── Telegram Notifications (optional) ────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get a token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your Telegram chat ID — get it from @userinfobot on Telegram
# Multiple IDs supported, comma-separated: 123456,789012
TELEGRAM_CHAT_IDS=your_chat_id
